{
  "id": "count-max-occurrences",
  "title": "Count occurrences of the maximum value",
  "description": "Find the maximum value first, then count how often it appears.",
  "solutionJava": "public static int countMaxOccurrences(List<Integer> numbers) {\n  int max = numbers.get(0);\n  for (int i = 1; i < numbers.size(); i += 1) {\n    if (numbers.get(i) > max) {\n      max = numbers.get(i);\n    }\n  }\n  int count = 0;\n  for (int i = 0; i < numbers.size(); i += 1) {\n    if (numbers.get(i) == max) {\n      count += 1;\n    }\n  }\n  return count;\n}",
