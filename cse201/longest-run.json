  "id": "longest-run",
  "title": "Find the longest consecutive identical run",
  "description": "Return the length of the longest streak of equal neighboring values.",
  "solutionJava": "public static int longestConsecutiveRun(List<Integer> numbers) {\n  int best = 1;\n  int current = 1;\n  for (int i = 1; i < numbers.size(); i += 1) {\n    if (numbers.get(i) == numbers.get(i - 1)) {\n      current += 1;\n      if (current > best) {\n        best = current;\n      }\n    } else {\n      current = 1;\n    }\n  }\n  return best;\n}",
