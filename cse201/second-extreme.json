{
  "id": "second-extreme",
  "title": "Second largest/smallest",
  "description": "Return the second distinct largest or smallest value. Mode is either \"largest\" or \"smallest\". Return null if no second distinct value exists.",
  "solutionJava": "public static int secondExtreme(List<Integer> numbers, String mode) {\n  List<Integer> unique = new ArrayList<>();\n  for (int i = 0; i < numbers.size(); i += 1) {\n    if (!unique.contains(numbers.get(i))) {\n      unique.add(numbers.get(i));\n    }\n  }\n  unique.sort((left, right) => left - right);\n  if (unique.size() < 2) {\n    return null;\n  }\n  return mode.equals(\"largest\") ? unique.get(unique.size() - 2) : unique.get(1);\n}",
