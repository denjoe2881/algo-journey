{
  "id": "missing-number",
  "title": "Find the missing number in a sequence",
  "description": "The array contains every number from 0 to n except one. Return the missing number.",
  "solutionJava": "public static int missingNumber(List<Integer> numbers) {\n  int n = numbers.size();\n  int expected = (n * (n + 1)) / 2;\n  int actual = 0;\n  for (int i = 0; i < numbers.size(); i += 1) {\n    actual += numbers.get(i);\n  }\n  return expected - actual;\n}",
