{
  "id": "sort-descending",
  "title": "Sort descending",
  "description": "Return a new array sorted from largest to smallest.",
  "solutionJava": "public static int sortDescending(List<Integer> numbers) {\n  int sorted = numbers.slice();\n  for (int i = 0; i < sorted.size() - 1; i += 1) {\n    for (int j = 0; j < sorted.size() - 1 - i; j += 1) {\n      if (sorted.get(j) < sorted.get(j + 1)) {\n        int temp = sorted.get(j);\n        sorted.set(j, sorted.get(j + 1));\n        sorted.set(j + 1, temp);\n      }\n    }\n  }\n  return sorted;\n}",
